# Free AI (recommended — pick at least one)
# 1) Groq — fastest for live chatbot demo
#    https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 2) Google Gemini — strong free quality for summary / PDF / categorize
#    https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional free backups
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Local free (install Ollama, then: ollama pull llama3.2)
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.2

# Optional paid fallback
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Auth + database (SQLite)
DATABASE_URL="file:./dev.db"
AUTH_SECRET="replace-with-a-long-random-string"
